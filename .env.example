# Database (Neon recommended)
DATABASE_URL=postgresql://...
DIRECT_URL=postgresql://...

# NextAuth v5
AUTH_SECRET=                        # Generate: openssl rand -base64 32
AUTH_URL=http://localhost:3000      # Production: https://yourdomain.com

# Resend
AUTH_RESEND_KEY=re_...
EMAIL_FROM=noreply@yourdomain.com

# Stripe
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Google Maps
GOOGLE_MAPS_API_KEY=                # Server-only: Distance Matrix API
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=    # Client: Places API (restrict by HTTP referrer)

# Upstash Redis (optional - rate limiting disabled without these)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Sentry
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=

# App Config
NEXT_PUBLIC_APP_URL=http://localhost:3000
BOOKING_ADVANCE_HOURS_MINIMUM=3
